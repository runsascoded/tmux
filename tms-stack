#!/usr/bin/env bash
# Create a project stack (tmux session/window with 2-3 panes).
#
# Default: creates a NEW session (1-window-per-session workflow).
# Use -w to add a window to the current session instead.
#
# Usage:
#   tms-stack [opts] [path] [name]
#   tms-stack -d [path] [name]       # 3-pane stack (claude + shell + dev server)
#   tms-stack -D CMD [path] [name]   # 3-pane stack with custom dev command
#   tms-stack -w [path] [name]       # add window to current session (not new session)
#
# path defaults to $PWD. name defaults to the directory basename.

set -euo pipefail

dev=false
no_dev=false
dev_cmd="npm run dev"
claude_args=""
add_to_session=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -2) no_dev=true; shift ;;
        -d) dev=true; shift ;;
        -D) dev=true; dev_cmd="$2"; shift 2 ;;
        -c) claude_args="$2"; shift 2 ;;
        -w) add_to_session=true; shift ;;
        -h|--help)
            echo "Usage: tms-stack [-d] [-D CMD] [-c CLAUDE_ARGS] [-w] [path] [name]"
            echo "  -w  Add window to current session (default: create new session)"
            exit 0
            ;;
        *) break ;;
    esac
done

path="${1:-$PWD}"
path="$(cd "$path" 2>/dev/null && pwd || echo "$path")"
name="${2:-$(basename "$path" | tr '.' '_')}"

# Auto-detect project type if not explicitly set
web_subdir=""
if [ -z "$claude_args" ]; then
    claude_args="-c"
    if [ -f "$path/package.json" ]; then
        claude_args="-c --chrome"
        if ! $dev && ! $no_dev; then
            dev=true
            dev_cmd="npm run dev"
        fi
    elif [ -f "$path/www/package.json" ]; then
        claude_args="-c --chrome"
        web_subdir="www"
        if ! $dev && ! $no_dev; then
            dev=true
            dev_cmd="cd www && npm run dev"
        fi
    elif [ -f "$path/site/package.json" ]; then
        claude_args="-c --chrome"
        web_subdir="site"
        if ! $dev && ! $no_dev; then
            dev=true
            dev_cmd="cd site && npm run dev"
        fi
    fi
fi
claude_cmd="claude $claude_args"

if $add_to_session; then
    # -w mode: add window to current session
    if [ -z "${TMUX:-}" ]; then
        echo "Error: -w requires being inside a tmux session" >&2
        exit 1
    fi
    session=$(tmux display-message -p '#{session_name}')
    attach_after=false
else
    # Default: create a new session
    session="$name"
    # Handle name collision
    if tmux has-session -t "=$session" 2>/dev/null; then
        # If existing session has a window at this path, just switch to it
        existing=$(tmux list-windows -t "=$session" -F '#{window_index} #{pane_current_path}' 2>/dev/null \
            | grep -F "$path" | head -1 | awk '{print $1}' || true)
        if [ -n "$existing" ]; then
            if [ -n "${TMUX:-}" ]; then
                tmux switch-client -t "=$session"
            else
                exec tmux attach -t "=$session"
            fi
            exit 0
        fi
        session="${name}-$(date +%s)"
    fi
    tmux new-session -d -s "$session" -c "$path"
    # Kill the placeholder window (will be replaced by our stack)
    placeholder=$(tmux list-windows -t "=$session" -F '#{window_index}' | head -1)
    attach_after=true
fi

if $dev; then
    # 3-pane stack: claude (top 50%) | shell (25%) | dev (25%)
    tmux new-window -t "=$session" -n "$name" -c "$path" \; \
        split-window -v -c "$path" -l 50% \; \
        split-window -v -c "$path" -l 50% \; \
        send-keys -t "{top}" "$claude_cmd" Enter \; \
        send-keys -t "{bottom}" "$dev_cmd" Enter \; \
        select-pane -t "{top}"
else
    # 2-pane stack: claude (top 70%) | shell (bottom 30%)
    tmux new-window -t "=$session" -n "$name" -c "$path" \; \
        split-window -v -c "$path" -l 30% \; \
        send-keys -t "{top}" "$claude_cmd" Enter \; \
        select-pane -t "{top}"
fi

# Kill placeholder window from new-session (if we created one)
if ! $add_to_session && [ -n "${placeholder:-}" ]; then
    tmux kill-window -t "=$session:$placeholder" 2>/dev/null || true
fi

if $attach_after; then
    if [ -n "${TMUX:-}" ]; then
        tmux switch-client -t "=$session"
    else
        exec tmux attach -t "=$session"
    fi
fi
